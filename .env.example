# Database - PostgreSQL
# Replace with your actual PostgreSQL credentials
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/ccit_connect"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Email (Brevo API - https://brevo.com)
BREVO_API_KEY="your-brevo-api-key-here"
BREVO_SENDER_EMAIL="noreply@ccit-connect.com"
BREVO_SENDER_NAME="CCIT CONNECT"

# Ably (for real-time features)
ABLY_API_KEY="your-ably-api-key"
